# Baidu Netdisk Skill — 凭证模板
# 复制本文件为 .env，然后填入真实值：
#   cp .env.example .env     (Linux / macOS / Git Bash)
#   copy .env.example .env   (Windows CMD)
#   然后 chmod 600 .env      (Linux / macOS)
#
# ⚠️ .env 已在 .gitignore 里，绝不会被 git 追踪
# ⚠️ BDUSS 等同账号密码，泄漏后他人可完全控制你的网盘

# 必填：从浏览器 F12 → Application → Cookies → pan.baidu.com 抓
BAIDU_BDUSS=

# 必填：同上位置抓，HttpOnly 必须在 Application 面板里看（不是 document.cookie）
BAIDU_STOKEN=

# 可选：填了请求更稳定，不填也能跑
BAIDU_BAIDUID=
